# Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Or alternatively:
# GOOGLE_API_KEY=your_google_api_key_here

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=logs/backend.log

# CORS Configuration (M1033 - System Access Control)
# Comma-separated list of allowed origins. Restrict to known frontend URLs.
# Only http:// and https:// URLs are accepted.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting (M1033 - System Access Control)
# Maximum number of API requests per IP per minute.
RATE_LIMIT_PER_MINUTE=60

# Frontend Configuration (if needed)
VITE_API_URL=http://localhost:8000
VITE_SSE_RECONNECT_ATTEMPTS=5
VITE_SSE_RECONNECT_DELAY=1000
