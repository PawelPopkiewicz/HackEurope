# Backend Configuration
API_HOST=127.0.0.1
API_PORT=8000
# SECURITY: keep debug mode OFF in production to prevent information disclosure
API_DEBUG=False

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Or alternatively:
# GOOGLE_API_KEY=your_google_api_key_here

# Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=logs/backend.log

# CORS — comma-separated list of allowed origins; never use * in production (M1016)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Internal service-to-service authentication token (M1016)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave unset (or set to empty string) only in debug/development environments.
INTERNAL_API_TOKEN=

# Session and connection limits (M1028)
SESSION_TIMEOUT=300
MAX_AUTH_ATTEMPTS=3

# Cowrie honeypot limits (M1028 / M1016)
COWRIE_SSH_AUTH_ATTEMPTS=3
COWRIE_SESSION_TIMEOUT=300

# Session watcher — path to the Cowrie JSON log (override for your environment)
COWRIE_LOG_FILE=/var/log/cowrie/cowrie.json
DASHBOARD_API_URL=http://localhost:8000/api/v1/dashboard/send_honeypot_json

# Frontend Configuration (if needed)
VITE_API_URL=http://localhost:8000
VITE_SSE_RECONNECT_ATTEMPTS=5
VITE_SSE_RECONNECT_DELAY=1000
